# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/ims-dashboard

# JWT Secret (cambia con una stringa casuale sicura in produzione)
JWT_SECRET=ims-dashboard-secret-key-change-in-production-2024

# Server Port
PORT=5000

# Frontend URL (per CORS)
FRONTEND_URL=http://localhost:3000

# Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
